<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.heartrate" android:required="false" />

    <!-- ── Sensores ─────────────────────────────────────────────────────────── -->
    <!-- Acesso ao sensor de batimentos cardíacos (foreground) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <!-- Acesso ao sensor em segundo plano (exigido pelo Android 13+ / API 33+) -->
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />
    <!-- Reconhecimento de atividade física (necessário em alguns Wear OS) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- ── Rede ──────────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── CPU / energia ─────────────────────────────────────────────────────── -->
    <!--
        WAKE_LOCK: mantém a CPU ativa mesmo com tela apagada.
        CRITICAL para monitoramento contínuo — sem isto, o Android suspende o
        processo e o sensor para de entregar leituras.
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Serviços em primeiro plano ────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Tipo "health" (paciente) — obrigatório targetSdk 34+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <!-- Tipo "dataSync" (cuidador) — obrigatório targetSdk 34+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- ── Boot ──────────────────────────────────────────────────────────────── -->
    <!-- Reinicia o monitoramento automaticamente após o relógio/celular ligar -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ── Notificações ──────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Exibe alerta mesmo com tela bloqueada (como alarme) no celular do cuidador -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!--
        SCHEDULE_EXACT_ALARM: necessário para que setExactAndAllowWhileIdle() funcione
        no Android 12+ (API 31+). Usado pelo HeartRateService.onTaskRemoved() para
        reagendar o serviço quando o usuário fecha o app — mesmo durante o modo Doze.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- ── Chamada telefônica ─────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- ── Notificação na tela de bloqueio ────────────────────────────────────── -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".EverNearApplication"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar">

        <!-- Tela inicial: seleção de papel (paciente/cuidador) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login / Cadastro -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!--
            Tela de configuração inicial de permissões.
            Exibida UMA VEZ após o primeiro login/cadastro, antes de entrar no app.
            Solicita todas as permissões necessárias abrindo diretamente os
            diálogos do sistema (sem telas intermediárias do nosso app).
        -->
        <activity
            android:name=".SetupPermissoesActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- Tela principal do paciente (monitor cardíaco) -->
        <activity
            android:name=".PatientActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- Dashboard do paciente: exibe código de sincronização -->
        <activity
            android:name=".DashboardPacienteActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- Tela do cuidador -->
        <activity
            android:name=".CaregiverActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- Dashboard do cuidador: vincular paciente -->
        <activity
            android:name=".DashboardCuidadorActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!--
            Serviço de monitoramento contínuo de batimentos cardíacos (PACIENTE — smartwatch).
            • foregroundServiceType="health" — identifica propósito para Android 14+ (API 34+)
            • START_STICKY — Android reinicia se encerrar o processo
            • stopWithTask="false" — CRÍTICO: sem este atributo, o Android encerra o serviço
              automaticamente quando o usuário fecha o app (remove dos recentes). Com ele,
              o serviço sobrevive ao fechamento do app e onTaskRemoved() é chamado para
              reagendar via AlarmManager se necessário.
            • WakeLock (adquirido internamente) — mantém CPU ativa mesmo com tela apagada
        -->
        <service
            android:name=".HeartRateService"
            android:exported="false"
            android:foregroundServiceType="health"
            android:stopWithTask="false" />

        <!--
            Serviço de recebimento de alertas (CUIDADOR — celular/tablet).
            • Mantém snapshot listener do Firestore ativo com app fechado
            • Exibe notificação de alta prioridade (com tela de bloqueio) ao receber alerta
        -->
        <service
            android:name=".CaregiverAlertService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            Receptor de boot — reinicia o serviço correto quando o dispositivo é ligado.
            directBootAware="false": aguarda o desencriptamento do armazenamento (padrão seguro).
            Cobre reinicializações normais e reboots rápidos de alguns fabricantes (Huawei/HTC).
        -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- Samsung / outros fabricantes -->
                <action android:name="com.sec.android.intent.action.LAUNCH_DATA_SETTINGS" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
