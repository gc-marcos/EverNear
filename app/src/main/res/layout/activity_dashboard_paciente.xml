<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Boas-vindas -->
        <TextView
            android:id="@+id/tv_welcome_paciente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, Paciente"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <!-- Apelido do paciente -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seu apelido"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <EditText
                android:id="@+id/et_apelido_paciente"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="#161B22"
                android:hint="Ex: Vovô, Maria, João"
                android:textColor="#FFFFFF"
                android:textColorHint="#9AA4B2"
                android:padding="12dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/btn_salvar_apelido_paciente"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="Salvar"
                android:backgroundTint="#1F6FEB"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Card: Código de Vínculo -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#161B22">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seu Código de Vínculo:"
                    android:textColor="#9AA4B2"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_codigo_vinculo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="------"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btn_share_codigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compartilhar Código"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#E10600" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status do vínculo -->
        <TextView
            android:id="@+id/tv_status_vinculo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compartilhe este código com seu cuidador"
            android:textColor="#9AA4B2"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:textAlignment="center" />

    </LinearLayout>
</ScrollView>
