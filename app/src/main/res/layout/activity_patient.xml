<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/image_bg"
    tools:context=".PatientActivity">

    <ImageView
        android:id="@+id/iv_heart_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_heart_heartbeat"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_bpm_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textSize="48sp"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/iv_heart_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_bpm_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="bpm"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tv_bpm_value"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Aguardando sensor..."
        android:textColor="#9AA4B2"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_bpm_label" />

    <!-- Limites configurados (mín/máx) -->
    <TextView
        android:id="@+id/tv_limites"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Limites: 50–120 bpm"
        android:textColor="#6E7681"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_status" />

    <!-- Botão de calibração -->
    <Button
        android:id="@+id/btn_calibrar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Calibrar (em repouso)"
        android:backgroundTint="#2EA043"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/btn_ver_codigo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Botão para ver o código de sincronização com o cuidador -->
    <Button
        android:id="@+id/btn_ver_codigo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ver Código de Sincronização"
        android:backgroundTint="#1F6FEB"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/btn_emergency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Botão de emergência -->
    <Button
        android:id="@+id/btn_emergency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="EMERGÊNCIA"
        android:backgroundTint="#FF0000"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:icon="@android:drawable/ic_dialog_alert" />

</androidx.constraintlayout.widget.ConstraintLayout>
