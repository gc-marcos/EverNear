<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Boas-vindas -->
        <TextView
            android:id="@+id/tv_welcome_cuidador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, Cuidador"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Apelido do cuidador -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seu apelido"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <EditText
                android:id="@+id/et_apelido_cuidador"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="#161B22"
                android:hint="Ex: Vovó, Pai, Enfermeiro João"
                android:textColor="#FFFFFF"
                android:textColorHint="#9AA4B2"
                android:padding="12dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/btn_salvar_apelido"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="Salvar"
                android:backgroundTint="#1F6FEB"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#21262D"
            android:layout_marginTop="24dp" />

        <!-- Vincular paciente -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vincular Novo Paciente"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/et_codigo_vincular"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="#161B22"
            android:hint="Digite o código de 6 dígitos"
            android:textColor="#FFFFFF"
            android:textColorHint="#9AA4B2"
            android:padding="12dp"
            android:maxLength="6"
            android:inputType="textCapCharacters" />

        <Button
            android:id="@+id/btn_vincular_paciente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vincular Paciente"
            android:layout_marginTop="12dp"
            android:backgroundTint="#E10600" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#21262D"
            android:layout_marginTop="24dp" />

        <!-- Lista de pacientes vinculados -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pacientes Vinculados"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <!-- Cards adicionados dinamicamente pelo Java -->
        <LinearLayout
            android:id="@+id/ll_lista_pacientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp" />

        <!-- Exibido quando não há pacientes -->
        <TextView
            android:id="@+id/tv_sem_pacientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhum paciente vinculado ainda.\nDigite o código acima para vincular."
            android:textColor="#9AA4B2"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
